spring:
  jwt:
      secret: your-super-secret-key-change-this
      issuer: xiaobantian-platform
      expire-minutes: 120
  application:
    name: xiaobantian-platform

  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/xiaobantian}
    username: ${SPRING_DATASOURCE_USERNAME:postgres}
    password: ${SPRING_DATASOURCE_PASSWORD:postgres}
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: ${SPRING_JPA_HIBERNATE_DDL_AUTO:update}
    show-sql: true
    open-in-view: false

  ai:
    model:
      audio:
        transcription: none

    openai:
      api-key: ${AI_API_KEY:}
      base-url: ${AI_BASE_URL:https://api.x.ai}

      chat:
        options:
          model: ${AI_CHAT_MODEL:grok-3-mini}
          temperature: 0.7

      embedding:
        options:
          model: ${AI_EMBEDDING_MODEL:text-embedding-ada-002}

server:
  port: 8080